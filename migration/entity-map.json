    "Application": { "target": "applications", "strategy": "direct-transform" },
    "Program": { "target": "programs", "strategy": "upsert-by-slug" },
    "Track": { "target": "program_tracks", "strategy": "upsert-by-program-and-slug" },
    "Batch": { "target": "cohorts", "strategy": "direct-transform" },
    "Enrollment": { "target": "enrollments", "strategy": "relationship-transform" },
    "AccessEntitlement": { "target": "access_entitlements", "strategy": "relationship-transform" },
    "Lesson": { "target": "lessons", "strategy": "versioned-transform" },
    "LessonProgress": { "target": "lesson_progress", "strategy": "relationship-transform" },
    "Submission": { "target": "submissions", "strategy": "direct-transform" },
    "SubmissionVersion": { "target": "submission_versions", "strategy": "immutable-transform" },
    "PortfolioAudit": { "target": "portfolio_audits", "strategy": "review-transform" },
    "Certificate": { "target": "credentials", "strategy": "credential-transform" },
    "SupportTicket": { "target": "support_tickets", "strategy": "direct-transform" },
    "Payment": { "target": "payments", "strategy": "financial-transform" },
    "Invoice": { "target": "invoices", "strategy": "financial-transform" },
    "Receipt": { "target": "receipts", "strategy": "financial-transform" },
    "Refund": { "target": "refunds", "strategy": "financial-transform" },
    "Announcement": { "target": "communications_pending", "strategy": "defer" },
    "Message": { "target": "messaging_pending", "strategy": "defer-until-participant-rls" }
  },
  "requiredLegacyFields": [
    "legacy_source",
    "legacy_id",
    "legacy_created_at",
    "migration_batch_id"
  ],
  "importOrder": [
    "Program",
    "Track",
    "Batch",
    "User",
    "ConsentRecord",
    "Application",
    "Waitlist",
    "Lead",
    "Enrollment",
    "AccessEntitlement",
    "Lesson",
    "LessonProgress",
    "Submission",
    "SubmissionVersion",
    "PortfolioAudit",
    "Certificate",
    "SupportTicket",
    "Payment",
    "Invoice",
    "Receipt",
    "Refund"
  ]
}
