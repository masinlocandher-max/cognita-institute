{
  "version": 1,
  "source": "base44",
  "target": "supabase-postgres",
  "entities": {
    "User": { "target": "profiles", "strategy": "auth-admin-import-plus-profile" },
    "ConsentRecord": { "target": "consent_records", "strategy": "direct-transform" },
    "Waitlist": { "target": "applications", "strategy": "admissions-transform" },
