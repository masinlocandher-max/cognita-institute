# Cognita frontend configuration
# Never put private service-role keys, SMTP credentials, or provider secrets here.

VITE_PUBLIC_SITE_URL=https://thecognitainstitute.com
VITE_DEPLOY_TARGET=custom-domain

# Backend feature flag. Keep `base44` until the migration preview is approved.
VITE_BACKEND_PROVIDER=base44

# Supabase frontend-safe values from the project Connect panel.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Legacy Base44 values retained only during migration and rollback.
VITE_BASE44_APP_ID=
VITE_BASE44_APP_BASE_URL=
VITE_BASE44_FUNCTIONS_VERSION=

# Server-only Edge Function secrets must be set with `supabase secrets set`.
# Do not add their values to this file:
# SUPABASE_SERVICE_ROLE_KEY
# RESEND_API_KEY
# COGNITA_FROM_EMAIL
# COGNITA_ADMISSIONS_EMAIL=cognitainstituteofai@gmail.com
# ALLOWED_ORIGINS=https://thecognitainstitute.com,https://www.thecognitainstitute.com
# TURNSTILE_SECRET_KEY
# IP_HASH_SALT
